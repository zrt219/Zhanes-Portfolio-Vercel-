{
  "name": "vercel-build-doctor-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "typecheck": "tsc --noEmit",
    "refresh:workflow-tracker": "node scripts/sync-workflow-tracker.mjs",
    "audit:45k": "vitest run --config vitest.audit.config.ts src/audit/premium-audit.test.ts",
    "audit:security": "vitest run --config vitest.audit.config.ts src/audit/security-audit.test.ts",
    "audit:report": "vitest run --config vitest.audit.config.ts src/audit/report-audit.test.ts"
  },
  "dependencies": {
    "ai": "^5.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
